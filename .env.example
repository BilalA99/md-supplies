# ─────────────────────────────────────────────────────────────────────────────
# md-supplies — environment template
#
# SETUP:  cp .env.example .env.local   then fill in the secret values.
# Get the real secret tokens from the team vault (1Password / secrets manager) —
# never commit .env.local, and never paste secrets into Slack/PRs.
#
# Values left blank below are SECRETS (per-team, do not commit).
# Values pre-filled below are NON-secret shared config (same for every developer).
# ─────────────────────────────────────────────────────────────────────────────

# ── Shopify store ────────────────────────────────────────────────────────────
# The store's myshopify domain (public). Shopify Admin → Settings → Domains.
SHOPIFY_STORE_DOMAIN=daebb2-76.myshopify.com

# ── Storefront API (product catalog, cart, search) ───────────────────────────
# SECRET. Shopify Admin → Sales channels → Headless/Storefront API → access token.
SHOPIFY_STOREFRONT_ACCESS_TOKEN=

# ── Admin API (server-side; currently unused by app code but referenced) ─────
# SECRET (shpca_…). Shopify Admin → Settings → Apps → custom app → Admin API token.
SHOPIFY_ADMIN_ACCESS_TOKEN=

# ── Customer Account API (login / orders / addresses) ────────────────────────
# OAuth base = https://shopify.com/authentication/<shop-id>  (NON-secret).
# The GraphQL API base is derived from this in lib/shopify/customer.ts.
SHOPIFY_CUSTOMER_ACCOUNT_URL=https://shopify.com/authentication/71167377624
# Public client ID (UUID) — it is sent to the browser in the OAuth redirect, so
# it is not a secret. Shopify Admin → Settings → Customer accounts → API.
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_ID=87bb2a4d-7725-4c9d-8494-84c908432f0f

# ── Site URL ─────────────────────────────────────────────────────────────────
# PER-DEVELOPER. The public HTTPS origin the app is reached at — used to build the
# OAuth redirect_uri (`${NEXT_PUBLIC_SITE_URL}/api/auth/callback`). No trailing slash.
#   • Local + ngrok:  your own ngrok static domain, e.g. https://<you>.ngrok-free.dev
#   • Staging/prod:   the deployed domain.
# Whatever you set here, its /api/auth/callback MUST be registered as a callback
# URI on the Customer Account API client above (and /account as a logout URI).
NEXT_PUBLIC_SITE_URL=https://your-tunnel.ngrok-free.dev

# ── Google Tag Manager ───────────────────────────────────────────────────────
# Non-secret container ID (same for every environment/developer).
NEXT_PUBLIC_GTM_ID=GTM-5BQJLLJV

# ── Resend (contact & sourcing forms) ────────────────────────────────────────
# SECRET. Create a free account at resend.com, verify your domain, then copy the key.
RESEND_API_KEY=re_...
# The "from" address — must use your verified domain (e.g. noreply@mdsupplies.com).
RESEND_FROM_EMAIL=noreply@mdsupplies.com
# Where form submissions are delivered (can be any address).
RESEND_TO_EMAIL=team@mdsupplies.com

# ── BunnyCDN (category/subcategory/product imagery) ──────────────────────────
# The md-supplies storage zone has no public Pull Zone, so reads go through the
# server-side proxy at app/api/bunny/[...path]/route.ts using the private
# Storage API. SECRET. BunnyCDN dashboard → Storage → md-supplies → FTP & API Access.
BUNNYCDN_STORAGE_ACCESS_KEY=
# Non-secret. Storage API host for the zone (BunnyCDN dashboard → Storage → md-supplies).
BUNNYCDN_STORAGE_HOSTNAME=ny.storage.bunnycdn.com
# Non-secret. The storage zone name.
BUNNYCDN_STORAGE_ZONE=md-supplies

# ── Optional flags ───────────────────────────────────────────────────────────
# Set to "true" on non-production deploys to flag the environment as staging.
NEXT_PUBLIC_IS_STAGING=
