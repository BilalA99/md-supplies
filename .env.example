# ── MDSupplies environment variables ─────────────────────────────────────────
# Copy to .env.local for development and fill in real values.
# Never commit real secrets. Deployment values live in the Vercel project env.

# ── Site identity ─────────────────────────────────────────────────────────────
# Canonical base URL for every canonical tag, og:url, sitemap entry, JSON-LD
# URL, and llms.txt. Defaults to https://mdsupplies.com when unset.
# PRODUCTION GUARD (lib/site-config.ts): a Vercel production deployment fails
# its build unless this is https://mdsupplies.com or https://www.mdsupplies.com.
# In dev this may be your ngrok tunnel (needed for Shopify login/webhooks).
NEXT_PUBLIC_SITE_URL=https://mdsupplies.com

# Staging override. Usually LEAVE UNSET: staging is auto-derived from Vercel's
# VERCEL_ENV (any non-production deploy is noindexed with a Disallow robots.txt
# and an empty sitemap). Set 'true' to force staging on a production-slot
# deploy that is not yet the live site (pre-domain-cutover); set 'false' to
# force live. Also gates GTM/analytics off while true.
# NEXT_PUBLIC_IS_STAGING=

# ── Shopify Storefront API ────────────────────────────────────────────────────
# Store domain, e.g. your-store.myshopify.com (no protocol).
SHOPIFY_STORE_DOMAIN=
# Storefront API access token (Headless / custom app → Storefront API).
SHOPIFY_STOREFRONT_ACCESS_TOKEN=
# Admin API access token (custom app → Admin API).
SHOPIFY_ADMIN_ACCESS_TOKEN=

# HMAC secret for verifying Shopify webhooks hitting POST /api/revalidate
# (Shopify admin → Settings → Notifications → Webhooks → shared secret).
SHOPIFY_WEBHOOK_SECRET=

# ── Shopify Customer Accounts (login / orders) ────────────────────────────────
# From the Customer Account API settings of the headless app.
SHOPIFY_CUSTOMER_ACCOUNT_URL=
SHOPIFY_CUSTOMER_ACCOUNT_CLIENT_ID=

# ── Email (Resend) ────────────────────────────────────────────────────────────
RESEND_API_KEY=
# Optional; defaults: noreply@mdsupplies.com / team@mdsupplies.com.
# RESEND_FROM_EMAIL=
# RESEND_TO_EMAIL=
# Optional override for sourcing-request notifications.
# RESEND_SOURCING_TO_EMAIL=

# ── BunnyCDN (category banners / product placeholders via /api/bunny) ────────
BUNNYCDN_STORAGE_ACCESS_KEY=
# Optional; defaults: ny.storage.bunnycdn.com / md-supplies.
# BUNNYCDN_STORAGE_HOSTNAME=
# BUNNYCDN_STORAGE_ZONE=

# ── Analytics ─────────────────────────────────────────────────────────────────
# Google Tag Manager container id (GTM-XXXXXXX). Omit to disable GTM.
# NEXT_PUBLIC_GTM_ID=
